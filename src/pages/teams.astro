---
import Layout from '../layouts/Layout.astro';

const sections = [
	{
		name: '机械组',
		desc: '负责整车机构、结构优化、装配调试与可靠性验证，是机器人实体能力的基础。',
	},
	{
		name: '电控组',
		desc: '负责 STM32 控制、驱动调试、CAN 通信、任务调度与核心控制逻辑实现。',
	},
	{
		name: '视觉组',
		desc: '负责识别、定位、目标解算与上位机联调，为整机提供感知和决策支持。',
	},
	{
		name: '硬件组',
		desc: '负责板级设计、接口选型、供电系统、传感器接入与硬件稳定性验证。',
	},
	{
		name: '运营组',
		desc: '负责战队宣传、内容整理、活动组织和对外展示，是团队协作与传播窗口。',
	},
];
---

<Layout title="小组方向 | 科来战队 Robomaster Lab">
	<div class="page">
		<header class="topbar">
			<a class="back-link" href="/robomaster-lab/">← 返回首页</a>
			<p class="eyebrow">TEAM DIRECTIONS</p>
			<h1>小组方向</h1>
			<p class="lead">
				战队按照 RoboMaster 实际研发流程划分多个方向，既有明确分工，也强调跨组协作与系统联调。
			</p>
		</header>

		<section class="grid">
			{sections.map((item) => (
				<article class="card">
					<h2>{item.name}</h2>
					<p>{item.desc}</p>
				</article>
			))}
		</section>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 28px 24px 64px;
	}

	.back-link {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}

	.eyebrow {
		margin: 22px 0 8px;
		letter-spacing: 0.2em;
		font-size: 12px;
		color: var(--text-strong);
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(36px, 6vw, 56px);
		color: var(--text-strong);
	}

	.lead,
	p {
		color: var(--text-muted);
		line-height: 1.8;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		margin-top: 24px;
	}

	.card {
		padding: 24px;
		border-radius: 20px;
		background: var(--card);
		border: 1px solid var(--border);
	}

	.card h2 {
		margin-top: 0;
		color: var(--text-strong);
	}

	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}

		.page {
			padding: 20px 16px 48px;
		}
	}
</style>
