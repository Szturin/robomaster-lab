---
import Layout from '../layouts/Layout.astro';

const sections = [
	{
		name: '机械组',
		desc: '负责结构设计、机构实现、整机装配与实车调试，是整车机械能力落地的核心方向。',
	},
	{
		name: '电控组',
		desc: '负责嵌入式开发、控制系统实现、通信链路与运动控制，是整机性能实现的关键方向。',
	},
	{
		name: '视觉组',
		desc: '负责 Linux 环境开发、MiniPC 部署、深度学习推理链路与模型训练优化。',
	},
	{
		name: '硬件组',
		desc: '负责 PCB 设计、接口与电源系统、传感器接入及电气可靠性验证。',
	},
	{
		name: '运营组',
		desc: '负责宣传招新、项目管理、物资统筹与对外联络，为战队持续运转提供支持。',
	},
];
---

<Layout
	title="小组方向 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的机械组、电控组、视觉组、硬件组与运营组分工，以及 RoboMaster 研发学习路径。"
	canonicalPath="/robomaster-lab/teams"
>
	<div class="page">
		<header class="topbar">
			<a class="back-link" href="/robomaster-lab/">← 返回首页</a>
			<p class="eyebrow">TEAM DIRECTIONS</p>
			<h1>小组方向</h1>
			<p class="lead">
				集美大学科来战队按照 RoboMaster 机器人研发流程划分机械组、电控组、视觉组、硬件组与运营组，各方向围绕设计、控制、感知、制造与赛事保障协同推进，强调跨组配合与整机联调。
			</p>
		</header>

		<section class="grid">
			{sections.map((item) => (
				<article class="card">
					<h2>{item.name}</h2>
					<p>{item.desc}</p>
				</article>
			))}
		</section>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 28px 24px 64px;
	}

	.back-link {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}

	.eyebrow {
		margin: 22px 0 8px;
		letter-spacing: 0.2em;
		font-size: 12px;
		color: var(--text-strong);
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(36px, 6vw, 56px);
		color: var(--text-strong);
	}

	.lead,
	p {
		color: var(--text-muted);
		line-height: 1.8;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		margin-top: 24px;
	}

	.card {
		padding: 24px;
		border-radius: 20px;
		background: var(--card);
		border: 1px solid var(--border);
	}

	.card h2 {
		margin-top: 0;
		color: var(--text-strong);
	}

	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}

		.page {
			padding: 20px 16px 48px;
		}
	}
</style>
