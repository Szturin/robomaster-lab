---
import Layout from '../layouts/Layout.astro';
import '../styles/subpage.css';
import '../styles/teams.css';
import { TEAM_SECTIONS } from '../data/team-sections';
---

<Layout
	title="成员培养 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的机械组、电控组、视觉组、硬件组与运营组培养路径，以及 RoboMaster 研发学习内容。"
	canonicalPath="/robomaster-lab/teams"
>
	<div class="page">
		<header class="topbar">
			<a class="back-link" href="/robomaster-lab/">← 返回首页</a>
			<p class="eyebrow">MEMBER DEVELOPMENT</p>
			<h1 class="page-title">成员培养</h1>
			<p class="lead">
				集美大学科来战队围绕 RoboMaster 机器人研发建立机械、电控、视觉、硬件与运营协同培养体系，帮助成员在真实项目、整机联调与赛事实践中逐步形成完整工程能力。
			</p>
		</header>

		<section class="grid two">
			{TEAM_SECTIONS.map((item) => (
				<article class="card">
					<h2>{item.name}</h2>
					<p>{item.trainingDescription}</p>
				</article>
			))}
		</section>
	</div>
</Layout>
