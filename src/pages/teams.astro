---
import Layout from '../layouts/Layout.astro';

const sections = [
	{
		name: '机械组',
		desc: '围绕结构设计、机构实现、整机装配与实车调试开展训练，帮助成员建立完整的机械工程实践能力。',
	},
	{
		name: '电控组',
		desc: '聚焦嵌入式开发、控制系统、通信链路与运动控制，让成员掌握机器人核心控制能力。',
	},
	{
		name: '视觉组',
		desc: '负责 Linux 开发、MiniPC 部署与深度学习模型训练，培养感知算法与系统部署能力。',
	},
	{
		name: '硬件组',
		desc: '围绕 PCB 设计、接口电源、传感器接入与电气验证开展实践，打牢硬件实现基础。',
	},
	{
		name: '运营组',
		desc: '参与宣传招新、项目管理、物资统筹与对外联络，提升团队协作与赛事保障能力。',
	},
];
---

<Layout
	title="成员培养 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的机械组、电控组、视觉组、硬件组与运营组培养路径，以及 RoboMaster 研发学习内容。"
	canonicalPath="/robomaster-lab/teams"
>
	<div class="page">
		<header class="topbar">
			<a class="back-link" href="/robomaster-lab/">← 返回首页</a>
			<p class="eyebrow">MEMBER DEVELOPMENT</p>
			<h1>成员培养</h1>
			<p class="lead">
				集美大学科来战队围绕 RoboMaster 机器人研发建立机械、电控、视觉、硬件与运营协同培养体系，帮助成员在真实项目、整机联调与赛事实践中逐步形成完整工程能力。
			</p>
		</header>

		<section class="grid">
			{sections.map((item) => (
				<article class="card">
					<h2>{item.name}</h2>
					<p>{item.desc}</p>
				</article>
			))}
		</section>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 28px 24px 64px;
	}

	.back-link {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}

	.eyebrow {
		margin: 22px 0 8px;
		letter-spacing: 0.2em;
		font-size: 12px;
		color: var(--text-strong);
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(36px, 6vw, 56px);
		color: var(--text-strong);
	}

	.lead,
	p {
		color: var(--text-muted);
		line-height: 1.8;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		margin-top: 24px;
	}

	.card {
		padding: 24px;
		border-radius: 20px;
		background: var(--card);
		border: 1px solid var(--border);
	}

	.card h2 {
		margin: 0 0 10px;
		color: var(--text-strong);
	}

	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
			gap: 14px;
			margin-top: 18px;
		}

		.page {
			padding: 20px 16px 48px;
		}

		.eyebrow {
			margin-top: 18px;
		}

		h1 {
			margin-bottom: 10px;
		}

		.lead {
			margin-bottom: 0;
		}

		.card {
			padding: 20px;
			border-radius: 18px;
		}
	}
</style>
