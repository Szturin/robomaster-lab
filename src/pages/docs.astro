---
import Layout from '../layouts/Layout.astro';

const groups = [
	{
		name: '机械组',
		docs: [
			{ title: '机械组文档', text: '围绕结构设计、机构实现、装配调试等内容整理的文档入口。' },
		],
	},
	{
		name: '电控组',
		docs: [
			{ title: '电控入门', text: '嵌入式开发、控制系统、通信链路与调参流程。' },
		],
	},
	{
		name: '视觉组',
		docs: [
			{ title: '视觉方案', text: 'Linux 开发、MiniPC 部署、模型训练与推理链路相关资料。' },
		],
	},
	{
		name: '硬件组',
		docs: [
			{ title: '硬件组文档', text: 'PCB设计、接口电源、传感器接入与电气验证文档入口。' },
		],
	},
	{
		name: '运营组',
		docs: [
			{ title: '比赛手册', text: '宣传招新、项目统筹、物资协调与赛事复盘资料。' },
		],
	},
];

const commonDocs = [
	{ title: '开发环境搭建', text: '包含工具链安装、仓库结构、基础约定。' },
	{
		title: '飞书知识文档',
		text: '查看战队飞书 Wiki 文档，获取更完整的内部资料与协作内容。',
		url: 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig',
	},
];
---

<Layout
	title="技术文档 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的技术文档、开发环境搭建说明、各组资料入口与飞书知识文档。"
	canonicalPath="/robomaster-lab/docs"
>
	<div class="page">
		<header class="topbar">
			<a href="/robomaster-lab/">← 返回首页</a>
			<h1>技术文档</h1>
			<p>这里汇总集美大学科来战队 TEF RoboMaster Lab 的技术文档、开发环境说明、各组资料入口与学习资料，服务于 RoboMaster 机器人研发、战队训练、新人入门与知识沉淀。</p>
		</header>

		<section class="panel common-panel">
			<h2>公共资料</h2>
			<div class="grid two">
				{commonDocs.map((item) => (
					item.url ? (
						<a class="card link-card" href={item.url} target="_blank" rel="noreferrer">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</a>
					) : (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					)
				))}
			</div>
		</section>

		<div class="groups">
			{groups.map((group) => (
				<section class="panel">
					<h2>{group.name}</h2>
					<div class="grid one">
						{group.docs.map((item) => (
							<article class="card">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
							</article>
						))}
					</div>
				</section>
			))}
		</div>
	</div>
</Layout>

<style>
	.page {
		max-width: 1100px;
		margin: 0 auto;
		padding: 32px 24px 64px;
	}

	.topbar a {
		text-decoration: none;
		color: var(--accent);
	}

	.topbar h1 {
		margin: 16px 0 8px;
		font-size: 42px;
		color: var(--text-strong);
	}

	.topbar p {
		color: var(--text-muted);
	}

	.groups {
		display: grid;
		gap: 20px;
		margin-top: 20px;
	}

	.panel {
		padding: 24px;
		border-radius: 24px;
		background: var(--card);
		border: 1px solid var(--border);
	}

	.common-panel {
		margin-top: 28px;
	}

	.panel h2 {
		margin-top: 0;
		color: var(--text-strong);
	}

	.grid {
		display: grid;
		gap: 18px;
		margin-top: 18px;
	}

	.one {
		grid-template-columns: 1fr;
	}

	.two {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.card {
		padding: 24px;
		border-radius: 20px;
		background: var(--card-soft);
		border: 1px solid var(--border);
	}

	.link-card {
		display: block;
		text-decoration: none;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	.link-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--accent) 42%, transparent);
		background: var(--accent-soft);
	}

	.card h3 {
		margin-top: 0;
		color: var(--text-strong);
	}

	.card p {
		color: var(--text-muted);
		line-height: 1.7;
	}

	@media (max-width: 720px) {
		.two {
			grid-template-columns: 1fr;
		}

		.page {
			padding: 20px 16px 48px;
		}
	}
</style>
