---
import Layout from '../layouts/Layout.astro';
import '../styles/docs.css';
import { SITE_LINKS } from '../data/site';
import { TEAM_SECTIONS } from '../data/team-sections';

const commonDocs = [
	{ title: '开发环境搭建', text: '面向新成员入门，包含工具链安装、仓库结构与基础协作约定。' },
	{
		title: '飞书知识文档',
		text: '查看战队飞书 Wiki 文档，获取更完整的内部资料与协作内容。',
		url: SITE_LINKS.feishuWiki,
	},
];
---

<Layout
	title="技术文档 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的技术文档、开发环境搭建说明、各组资料入口与飞书知识文档。"
	canonicalPath="/robomaster-lab/docs"
>
	<div class="page">
		<header class="topbar">
			<a href="/robomaster-lab/">← 返回首页</a>
			<h1>技术文档</h1>
			<p>这里汇总战队的技术文档、开发环境说明、各组资料入口与学习材料，服务于项目研发、成员培养、新人入门与知识沉淀。</p>
		</header>

		<section class="panel common-panel">
			<h2>公共资料</h2>
			<div class="grid two">
				{commonDocs.map((item) => (
					item.url ? (
						<a class="card link-card" href={item.url} target="_blank" rel="noreferrer">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</a>
					) : (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					)
				))}
			</div>
		</section>

		<div class="groups">
			{TEAM_SECTIONS.map((group) => (
				<section class="panel">
					<h2>{group.name}</h2>
					<div class="grid one">
						<article class="card">
							<h3>{`${group.name}资料`}</h3>
							<p>{group.docsDescription}</p>
						</article>
					</div>
				</section>
			))}
		</div>
	</div>
</Layout>
