---
import Layout from '../layouts/Layout.astro';

const docs = [
	{ title: '开发环境搭建', text: '包含工具链安装、仓库结构、基础约定。' },
	{ title: '电控入门', text: 'STM32、CAN 通信、任务调度、调参流程。' },
	{ title: '视觉方案', text: '识别链路、串口协议、上位机联调。' },
	{ title: '比赛手册', text: '兵种分工、赛前检查、问题复盘。' },
];
---

<Layout title="技术文档 | RoboMaster Lab">
	<div class="page">
		<header class="topbar">
			<a href="/robomaster-lab/">← 返回首页</a>
			<h1>技术文档</h1>
			<p>这里先放一个文档入口页，后续可以继续拆成 Markdown 或 Astro 页面。</p>
		</header>

		<section class="grid">
			{docs.map((item) => (
				<article class="card">
					<h2>{item.title}</h2>
					<p>{item.text}</p>
				</article>
			))}
		</section>
	</div>
</Layout>

<style>
	.page {
		max-width: 1100px;
		margin: 0 auto;
		padding: 32px 24px 64px;
	}

	.topbar a {
		text-decoration: none;
		color: #7ab8ff;
	}

	.topbar h1 {
		margin: 16px 0 8px;
		font-size: 42px;
	}

	.topbar p {
		color: #b9c7d8;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		margin-top: 28px;
	}

	.card {
		padding: 24px;
		border-radius: 20px;
		background: rgba(10, 20, 35, 0.72);
		border: 1px solid rgba(140, 168, 197, 0.16);
	}

	.card h2 {
		margin-top: 0;
	}

	.card p {
		color: #b9c7d8;
		line-height: 1.7;
	}

	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}

		.page {
			padding: 20px 16px 48px;
		}
	}
</style>
