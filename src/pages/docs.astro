---
import Layout from '../layouts/Layout.astro';
import '../styles/docs.css';

const groups = [
	{
		name: '机械组',
		docs: [{ title: '机械组资料', text: '围绕结构设计、机构实现、装配调试等内容整理的资料入口。' }],
	},
	{
		name: '电控组',
		docs: [{ title: '电控组资料', text: '嵌入式开发、控制系统、通信链路与调参流程。' }],
	},
	{
		name: '视觉组',
		docs: [{ title: '视觉组资料', text: 'Linux 开发、MiniPC 部署、模型训练与推理链路相关资料。' }],
	},
	{
		name: '硬件组',
		docs: [{ title: '硬件组资料', text: 'PCB 设计、接口电源、传感器接入与电气验证资料入口。' }],
	},
	{
		name: '运营组',
		docs: [{ title: '运营组资料', text: '宣传招新、项目统筹、物资协调与赛事复盘资料。' }],
	},
];

const commonDocs = [
	{ title: '开发环境搭建', text: '面向新成员入门，包含工具链安装、仓库结构与基础协作约定。' },
	{
		title: '飞书知识文档',
		text: '查看战队飞书 Wiki 文档，获取更完整的内部资料与协作内容。',
		url: 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig',
	},
];
---

<Layout
	title="技术文档 | 集美大学科来战队 RoboMaster Lab"
	description="查看集美大学科来战队 RoboMaster Lab 的技术文档、开发环境搭建说明、各组资料入口与飞书知识文档。"
	canonicalPath="/robomaster-lab/docs"
>
	<div class="page">
		<header class="topbar">
			<a href="/robomaster-lab/">← 返回首页</a>
			<h1>技术文档</h1>
			<p>这里汇总战队的技术文档、开发环境说明、各组资料入口与学习材料，服务于项目研发、成员培养、新人入门与知识沉淀。</p>
		</header>

		<section class="panel common-panel">
			<h2>公共资料</h2>
			<div class="grid two">
				{commonDocs.map((item) => (
					item.url ? (
						<a class="card link-card" href={item.url} target="_blank" rel="noreferrer">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</a>
					) : (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					)
				))}
			</div>
		</section>

		<div class="groups">
			{groups.map((group) => (
				<section class="panel">
					<h2>{group.name}</h2>
					<div class="grid one">
						{group.docs.map((item) => (
							<article class="card">
								<h3>{item.title}</h3>
								<p>{item.text}</p>
							</article>
						))}
					</div>
				</section>
			))}
		</div>
	</div>
</Layout>
