---
import Layout from '../layouts/Layout.astro';
import '../styles/subpage.css';
import '../styles/about.css';

const highlights = [
	{ title: '工程驱动', text: '以 RoboMaster 赛题为牵引，围绕整机工程、系统联调和真实比赛场景开展协作。' },
	{ title: '技术沉淀', text: '把调试记录、项目复盘、技术方案和开发手册沉淀为团队可复用资产。' },
	{ title: '开放成长', text: '鼓励跨方向协作与成员培养，让大家在实战中形成更完整的工程视角。' },
];
---

<Layout
	title="关于我们 | 集美大学科来战队 RoboMaster Lab"
	description="了解集美大学科来战队 RoboMaster Lab 的团队定位、工程实践方向、比赛目标与技术沉淀方式。"
	canonicalPath="/robomaster-lab/about"
>
	<div class="page">
		<header class="topbar">
			<a class="back-link" href="/robomaster-lab/">← 返回首页</a>
			<p class="eyebrow">ABOUT KELAI TEAM</p>
			<h1 class="page-title">关于我们</h1>
			<p class="lead">
				科来战队 TEF RoboMaster Lab 是集美大学面向 RoboMaster 高校赛事的工程实践平台，围绕机器人研发、系统联调、团队协作与技术传承展开长期建设，持续打磨面向比赛的整机能力与工程体系。
			</p>
		</header>

		<section class="panel">
			<h2>团队定位</h2>
			<div class="grid three">
				{highlights.map((item) => (
					<article class="card">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="panel narrative">
			<div>
				<h2>我们在做什么</h2>
				<p>从机械结构设计、电控系统实现，到视觉感知与上位机协同，团队围绕完整机器人系统开展研发。</p>
			</div>
			<div>
				<h2>我们想沉淀什么</h2>
				<p>除了参赛成果，更重视技术复盘、知识整理、开发流程规范与团队协作方法，让经验可以被后来者继承。</p>
			</div>
		</section>
	</div>
</Layout>
