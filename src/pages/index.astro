---
import Layout from '../layouts/Layout.astro';

const highlights = [
	{ title: '机器人开发', text: '围绕 RoboMaster 开展机械、电控、视觉与整机协同开发。' },
	{ title: '赛事积累', text: '沉淀比赛经验、项目复盘、调试记录与工程资料。' },
	{ title: '开放协作', text: '欢迎对机器人、嵌入式、算法与赛事工程感兴趣的同学加入。' },
];

const sections = [
	{ name: '机械组', desc: '机构设计、加工装配、结构优化与实车调试。' },
	{ name: '电控组', desc: 'STM32、驱动控制、CAN 通信、任务调度与算法实现。' },
	{ name: '视觉组', desc: '目标识别、定位解算、串口联调与上位机协作。' },
	{ name: '运营组', desc: '战队宣传、活动组织、内容运营与对外展示。' },
];

const feishuInviteUrl = 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM';
---

<Layout title="科来战队 Robomaster Lab">
	<div class="page">
		<header class="hero">
			<nav class="nav">
				<div class="brand">科来战队 Robomaster Lab</div>
				<div class="links">
					<a href="#about">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M12 2.5 4 6v5.2c0 5.1 3.45 9.86 8 11.3 4.55-1.44 8-6.2 8-11.3V6l-8-3.5Zm0 2.18L18 7.3v3.9c0 4.05-2.57 7.96-6 9.28-3.43-1.32-6-5.23-6-9.28V7.3l6-2.62Z" />
						</svg>
						<span>关于我们</span>
					</a>
					<a href="#teams">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M6.5 6a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Zm11 0a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM12 11a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm-5.5 2c1.83 0 3.4.8 4.5 2.06A5.97 5.97 0 0 0 8 20H3.5v-1A6 6 0 0 1 6.5 13Zm11 0A6 6 0 0 1 20.5 19v1H16a5.97 5.97 0 0 0-3-4.94A5.98 5.98 0 0 1 17.5 13ZM12 18a4 4 0 0 1 4 4H8a4 4 0 0 1 4-4Z" />
						</svg>
						<span>小组方向</span>
					</a>
					<a href="/robomaster-lab/docs">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M6 3.5A2.5 2.5 0 0 0 3.5 6v12A2.5 2.5 0 0 0 6 20.5h12a2.5 2.5 0 0 0 2.5-2.5V8.41a2.5 2.5 0 0 0-.73-1.77l-2.41-2.41A2.5 2.5 0 0 0 15.59 3.5H6Zm0 1.5h9v3a1 1 0 0 0 1 1h3v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" />
						</svg>
						<span>技术文档</span>
					</a>
					<a href={feishuInviteUrl} target="_blank" rel="noreferrer">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d="M19.45 4.44c-1.32-.83-3.75-.76-5.73.26L8.4 7.45 5.2 7.1a1.6 1.6 0 0 0-1.75 1.97l.7 2.75-1.53 4.6a1.65 1.65 0 0 0 2.09 2.08l4.56-1.55 2.76.7a1.6 1.6 0 0 0 1.96-1.74l-.35-3.23 2.75-5.3c1.02-1.98 1.09-4.4.26-5.74-.26-.42-.63-.78-1.2-1.14Z" />
						</svg>
						<span>加入我们</span>
					</a>
				</div>
			</nav>

			<section class="hero-main">
				<div class="hero-copy">
					<p class="eyebrow">KELAI TEAM · ROBOMASTER LAB</p>
					<h1>科来战队 Robomaster Lab</h1>
					<p class="lead">
						展示战队风采、沉淀技术资料、组织招新协作，服务于 RoboMaster 项目展示与团队建设。
					</p>
					<div class="actions">
						<a class="primary" href={feishuInviteUrl} target="_blank" rel="noreferrer">立即加入飞书群</a>
						<a class="secondary" href="/robomaster-lab/docs">进入文档区</a>
					</div>
				</div>
				<div class="hero-card">
					<div class="metric"><span>4</span><label>核心方向</label></div>
					<div class="metric"><span>24h</span><label>开放协作节奏</label></div>
					<div class="metric"><span>GitHub Pages</span><label>免费托管</label></div>
				</div>
			</section>
		</header>

		<main>
			<section id="about" class="panel">
				<h2>实验室定位</h2>
				<div class="grid three">
					{highlights.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section id="teams" class="panel">
				<h2>小组方向</h2>
				<div class="grid four">
					{sections.map((item) => (
						<article class="card compact">
							<h3>{item.name}</h3>
							<p>{item.desc}</p>
						</article>
					))}
				</div>
			</section>

			<section class="panel callout">
				<div>
					<h2>欢迎加入科来战队 Robomaster Lab</h2>
					<p>你可以继续补充队伍成员页、比赛成绩页、招新页、项目展示页和开发手册页。</p>
				</div>
				<a class="primary" href={feishuInviteUrl} target="_blank" rel="noreferrer">通过飞书加入</a>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px;
	}

	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 0 28px;
	}

	.brand {
		font-size: 20px;
		font-weight: 700;
	}

	.links {
		display: flex;
		gap: 14px;
		color: #ffffff;
	}

	.links a,
	.actions a {
		text-decoration: none;
	}

	.links a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 14px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: #ffffff;
		font-weight: 600;
		letter-spacing: 0.01em;
		transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
	}

	.links a:hover {
		transform: translateY(-2px);
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.28);
	}

	.links a svg {
		width: 16px;
		height: 16px;
		color: #ffffff;
		flex: none;
	}

	.hero-main {
		display: grid;
		grid-template-columns: 1.4fr 0.8fr;
		gap: 24px;
		align-items: center;
		padding: 36px 0 28px;
	}

	.eyebrow {
		color: #d7e3f3;
		letter-spacing: 0.22em;
		font-size: 12px;
	}

	h1 {
		font-size: clamp(38px, 6vw, 64px);
		line-height: 1.1;
		margin: 12px 0 20px;
		text-shadow: 0 0 24px rgba(255, 255, 255, 0.08);
	}

	.lead,
	p {
		color: #c8d4e2;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		gap: 16px;
		margin-top: 28px;
	}

	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 12px;
		font-weight: 700;
	}

	.primary {
		background: linear-gradient(135deg, #f5f7fb, #cfd8e6);
		color: #07111f;
		box-shadow: 0 10px 30px rgba(255, 255, 255, 0.12);
	}

	.secondary {
		border: 1px solid rgba(255, 255, 255, 0.18);
		background: rgba(255, 255, 255, 0.03);
		color: #ffffff;
	}

	.hero-card,
	.card,
	.panel {
		background: rgba(10, 20, 35, 0.72);
		border: 1px solid rgba(140, 168, 197, 0.16);
		backdrop-filter: blur(14px);
	}

	.hero-card {
		border-radius: 20px;
		padding: 24px;
		display: grid;
		gap: 16px;
	}

	.metric {
		padding: 16px;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.03);
	}

	.metric span {
		display: block;
		font-size: 28px;
		font-weight: 700;
		margin-bottom: 6px;
	}

	.metric label {
		color: #9eb0c7;
	}

	main {
		display: grid;
		gap: 24px;
		padding: 12px 0 48px;
	}

	.panel {
		border-radius: 24px;
		padding: 28px;
	}

	.grid {
		display: grid;
		gap: 16px;
		margin-top: 18px;
	}

	.three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.four {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.card {
		border-radius: 18px;
		padding: 20px;
	}

	.compact h3,
	.card h3 {
		margin-top: 0;
	}

	.callout {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}

	@media (max-width: 900px) {
		.hero-main,
		.three,
		.four,
		.callout {
			grid-template-columns: 1fr;
			display: grid;
		}

		.nav {
			flex-direction: column;
			gap: 16px;
		}
	}

	@media (max-width: 640px) {
		.page {
			padding: 16px;
		}

		.links,
		.actions {
			flex-direction: column;
		}
	}
</style>