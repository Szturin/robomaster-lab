---
import Layout from '../layouts/Layout.astro';

const highlights = [
	{ title: '机器人开发', text: '底盘、云台、视觉、嵌入式控制一体化协作。' },
	{ title: '赛事积累', text: '沉淀 RoboMaster 参赛经验、方案复盘与工程文档。' },
	{ title: '开放协作', text: '面向新成员提供入门路径、任务地图与知识索引。' },
];

const sections = [
	{ name: '机械组', desc: '机构设计、加工装配、结构优化。' },
	{ name: '电控组', desc: 'STM32、驱动板、控制算法、通信链路。' },
	{ name: '视觉组', desc: '目标识别、定位解算、上位机协同。' },
	{ name: '运营组', desc: '宣传内容、活动组织、文档建设。' },
];
---

<Layout title="RoboMaster Lab">
	<div class="page">
		<header class="hero">
			<nav class="nav">
				<div class="brand">RoboMaster Lab</div>
				<div class="links">
					<a href="#about">关于我们</a>
					<a href="#teams">小组方向</a>
					<a href="/robomaster-lab/docs">技术文档</a>
				</div>
			</nav>

			<section class="hero-main">
				<div class="hero-copy">
					<p class="eyebrow">BUILD · TEST · COMPETE</p>
					<h1>面向 RoboMaster 的实验室展示站与技术文档中心</h1>
					<p class="lead">
						展示团队、沉淀知识、组织协作。适合放比赛成果、成员介绍、开发规范与项目文档。
					</p>
					<div class="actions">
						<a class="primary" href="#about">了解实验室</a>
						<a class="secondary" href="/robomaster-lab/docs">进入文档区</a>
					</div>
				</div>
				<div class="hero-card">
					<div class="metric"><span>4</span><label>核心方向</label></div>
					<div class="metric"><span>24h</span><label>开放协作节奏</label></div>
					<div class="metric"><span>GitHub Pages</span><label>免费托管</label></div>
				</div>
			</section>
		</header>

		<main>
			<section id="about" class="panel">
				<h2>实验室定位</h2>
				<div class="grid three">
					{highlights.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section id="teams" class="panel">
				<h2>小组方向</h2>
				<div class="grid four">
					{sections.map((item) => (
						<article class="card compact">
							<h3>{item.name}</h3>
							<p>{item.desc}</p>
						</article>
					))}
				</div>
			</section>

			<section class="panel callout">
				<div>
					<h2>下一步你可以继续加什么</h2>
					<p>队伍成员页、比赛成绩页、招新页、项目展示页、开发手册页。</p>
				</div>
				<a class="primary" href="/robomaster-lab/docs">先看文档模板</a>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px;
	}

	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 0 28px;
	}

	.brand {
		font-size: 20px;
		font-weight: 700;
	}

	.links {
		display: flex;
		gap: 20px;
		color: #b9c7d8;
	}

	.links a,
	.actions a {
		text-decoration: none;
	}

	.hero-main {
		display: grid;
		grid-template-columns: 1.4fr 0.8fr;
		gap: 24px;
		align-items: center;
		padding: 36px 0 28px;
	}

	.eyebrow {
		color: #7ab8ff;
		letter-spacing: 0.18em;
		font-size: 12px;
	}

	h1 {
		font-size: clamp(38px, 6vw, 64px);
		line-height: 1.1;
		margin: 12px 0 20px;
	}

	.lead,
	p {
		color: #b9c7d8;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		gap: 16px;
		margin-top: 28px;
	}

	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 12px;
		font-weight: 600;
	}

	.primary {
		background: linear-gradient(135deg, #2563eb, #38bdf8);
		color: white;
	}

	.secondary {
		border: 1px solid rgba(145, 170, 199, 0.3);
		background: rgba(255, 255, 255, 0.03);
	}

	.hero-card,
	.card,
	.panel {
		background: rgba(10, 20, 35, 0.72);
		border: 1px solid rgba(140, 168, 197, 0.16);
		backdrop-filter: blur(14px);
	}

	.hero-card {
		border-radius: 20px;
		padding: 24px;
		display: grid;
		gap: 16px;
	}

	.metric {
		padding: 16px;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.03);
	}

	.metric span {
		display: block;
		font-size: 28px;
		font-weight: 700;
		margin-bottom: 6px;
	}

	.metric label {
		color: #9eb0c7;
	}

	main {
		display: grid;
		gap: 24px;
		padding: 12px 0 48px;
	}

	.panel {
		border-radius: 24px;
		padding: 28px;
	}

	.grid {
		display: grid;
		gap: 16px;
		margin-top: 18px;
	}

	.three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.four {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.card {
		border-radius: 18px;
		padding: 20px;
	}

	.compact h3,
	.card h3 {
		margin-top: 0;
	}

	.callout {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}

	@media (max-width: 900px) {
		.hero-main,
		.three,
		.four,
		.callout {
			grid-template-columns: 1fr;
			display: grid;
		}

		.nav {
			flex-direction: column;
			gap: 16px;
		}
	}

	@media (max-width: 640px) {
		.page {
			padding: 16px;
		}

		.links,
		.actions {
			flex-direction: column;
		}
	}
</style>