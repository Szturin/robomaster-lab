---
import Layout from '../layouts/Layout.astro';
import '../styles/index.css';
import { SITE_LINKS, SITE_META } from '../data/site';
import { TEAM_SECTIONS } from '../data/team-sections';

const highlights = [
	{ title: '机器人开发', text: '围绕 RoboMaster 开展机械、电控、视觉与整机协同开发。' },
	{ title: '赛事积累', text: '沉淀比赛经验、项目复盘、调试记录与工程资料。' },
	{ title: '开放协作', text: '欢迎对机器人、嵌入式、算法与赛事工程感兴趣的同学加入。' },
];
---

<Layout
	title="集美大学科来战队 RoboMaster Lab | 战队展示与技术文档"
	description="集美大学科来战队 RoboMaster Lab 官方展示页，包含战队介绍、成员培养、RoboMaster 技术文档、项目展示与招新协作入口。"
	canonicalPath="/robomaster-lab/"
>
	<div class="page">
		<header class="hero">
			<nav class="nav reveal-sequence reveal-delay-0">
				<div class="brand">TEF Robomaster Lab</div>
				<div class="nav-right">
					<form class="nav-search" action={SITE_LINKS.searchAction} method="get" target="_blank" rel="noreferrer">
						<input type="hidden" name="q" value={SITE_META.searchQuery} data-search-base />
						<label class="search-field">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M10.5 4a6.5 6.5 0 1 1 0 13 6.5 6.5 0 0 1 0-13Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Zm8.91 11.5 1.59 1.59-1.41 1.41L18 18.91l1.41-1.41Z" />
							</svg>
							<input type="search" name="keyword" placeholder="搜索站内内容" aria-label="搜索站内内容" data-search-input />
						</label>
					</form>
					<div class="links">
						<a href={SITE_LINKS.robomaster} target="_blank" rel="noreferrer">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M5 4h6.6c3.62 0 5.9 1.86 5.9 4.82 0 2.04-1.04 3.47-2.9 4.12L19 20h-3.95l-3.87-6.43H8.4V20H5V4Zm3.4 2.72v4.2h3c1.67 0 2.58-.71 2.58-2.08 0-1.4-.9-2.12-2.58-2.12h-3Z" />
							</svg>
							<span>赛事官网</span>
						</a>
						<a href="/robomaster-lab/about">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M12 2.5 4 6v5.2c0 5.1 3.45 9.86 8 11.3 4.55-1.44 8-6.2 8-11.3V6l-8-3.5Zm0 2.18L18 7.3v3.9c0 4.05-2.57 7.96-6 9.28-3.43-1.32-6-5.23-6-9.28V7.3l6-2.62Z" />
							</svg>
							<span>关于我们</span>
						</a>
						<a href="/robomaster-lab/docs">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M6 3.5A2.5 2.5 0 0 0 3.5 6v12A2.5 2.5 0 0 0 6 20.5h12a2.5 2.5 0 0 0 2.5-2.5V8.41a2.5 2.5 0 0 0-.73-1.77l-2.41-2.41A2.5 2.5 0 0 0 15.59 3.5H6Zm0 1.5h9v3a1 1 0 0 0 1 1h3v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" />
							</svg>
							<span>技术文档</span>
						</a>
						<a href={SITE_LINKS.feishuInvite} data-disabled-invite>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M19.45 4.44c-1.32-.83-3.75-.76-5.73.26L8.4 7.45 5.2 7.1a1.6 1.6 0 0 0-1.75 1.97l.7 2.75-1.53 4.6a1.65 1.65 0 0 0 2.09 2.08l4.56-1.55 2.76.7a1.6 1.6 0 0 0 1.96-1.74l-.35-3.23 2.75-5.3c1.02-1.98 1.09-4.4.26-5.74-.26-.42-.63-.78-1.2-1.14Z" />
							</svg>
							<span>加入我们</span>
						</a>
					</div>
					<button type="button" class="theme-button nav-theme" data-theme-choice="system" aria-label="切换主题" title="切换主题">
						<svg viewBox="0 0 24 24" aria-hidden="true" data-theme-icon data-theme-state="system">
							<path class="sun-core" fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z" />
							<path class="sun-rays" fill="currentColor" d="M11 1h2v3h-2V1Zm0 19h2v3h-2v-3ZM1 11h3v2H1v-2Zm19 0h3v2h-3v-2ZM4.22 5.64l1.42-1.42 2.12 2.12-1.41 1.42-2.13-2.12Zm12.03 12.02 1.42-1.41 2.12 2.12-1.41 1.41-2.13-2.12ZM16.25 6.34l2.12-2.12 1.41 1.42-2.12 2.12-1.41-1.42ZM4.22 18.36l2.12-2.12 1.42 1.41-2.12 2.13-1.42-1.42Z" />
							<path class="moon-shape" fill="currentColor" d="M15.77 4.58A7.5 7.5 0 1 0 19.42 16a8 8 0 1 1-3.65-11.42Z" />
						</svg>
					</button>
				</div>
			</nav>

			<section class="hero-main">
				<div class="hero-ambient" aria-hidden="true">
					<span class="hero-orb orb-one"></span>
					<span class="hero-orb orb-two"></span>
					<span class="hero-scan"></span>
				</div>
				<div class="hero-copy">
					<p class="eyebrow reveal-sequence reveal-delay-1">TEF · ROBOMASTER LAB</p>
					<h1 class="typing-heading reveal-delay-2" data-typing-text="TEF Robomaster Lab" aria-label="TEF Robomaster Lab">
						<span class="typing-text" aria-hidden="true"></span>
					</h1>
					<p class="lead reveal-sequence reveal-delay-3">
						这里是集美大学科来战队 TEF RoboMaster Lab 的对外展示站，面向 RoboMaster 高校赛事与机器人工程实践，集中展示战队建设、技术文档、成员培养与招新协作信息。
					</p>
					<div class="actions reveal-sequence reveal-delay-4">
						<a class="primary" href={SITE_LINKS.feishuWiki} target="_blank" rel="noreferrer">飞书文档</a>
						<a class="secondary" href="/robomaster-lab/docs">技术文档</a>
					</div>
				</div>
				<div class="hero-card reveal-sequence reveal-delay-5">
					<div class="metric"><span>前沿技术</span><label>聚焦具身智能、机器人设计与控制工程</label></div>
					<div class="metric"><span>自主创新</span><label>软件、硬件、机械系统自主研发</label></div>
					<div class="metric"><span>赛事驱动</span><label>以赛促研，持续迭代</label></div>
				</div>
			</section>
		</header>

		<main>
			<section id="about" class="panel reveal-on-scroll">
				<div class="section-head">
					<div>
						<h2>关于我们</h2>
						<p class="section-note">主页保留简介，完整介绍请进入集美大学科来战队详情页。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/about">查看科来战队介绍</a>
				</div>
				<div class="grid three">
					{highlights.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section id="teams" class="panel reveal-on-scroll">
				<div class="section-head">
					<div>
						<h2>成员培养</h2>
						<p class="section-note">主页展示 RoboMaster 分工概览，详细职责与培养路径见子页面。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/teams">查看成员培养详情</a>
				</div>
				<div class="team-switcher" aria-label="成员培养内容切换">
					<input class="team-toggle" type="radio" name="team-page" id="team-page-1" checked />
					<input class="team-toggle" type="radio" name="team-page" id="team-page-2" />

					<div class="team-pages">
						<div class="team-page page-one">
							{TEAM_SECTIONS.slice(0, 3).map((item) => (
								<article class="card compact team-card">
									<h3>{item.name}</h3>
									<p>{item.summary}</p>
								</article>
							))}
						</div>
						<div class="team-page page-two">
							{TEAM_SECTIONS.slice(3).map((item) => (
								<article class="card compact team-card">
									<h3>{item.name}</h3>
									<p>{item.summary}</p>
								</article>
							))}
						</div>
					</div>

					<div class="team-dots">
						<label for="team-page-1" aria-label="查看第一页"></label>
						<label for="team-page-2" aria-label="查看第二页"></label>
					</div>
				</div>
			</section>

			<section class="panel callout reveal-on-scroll">
				<div>
					<h2>欢迎加入 TEF Robomaster Lab</h2>
					<p>后续将逐步完善队伍成员、比赛成绩、招新信息、项目展示与开发手册等内容。</p>
				</div>
				<a class="primary" href={SITE_LINKS.feishuInvite} data-disabled-invite>通过飞书加入</a>
			</section>
		</main>
	</div>

	<script is:inline>
		(() => {
			const searchForm = document.querySelector('.nav-search');
			const searchInput = searchForm?.querySelector('[data-search-input]');
			const searchBase = searchForm?.querySelector('[data-search-base]');
			if (searchForm && searchInput instanceof HTMLInputElement && searchBase instanceof HTMLInputElement) {
				searchForm.addEventListener('submit', () => {
					const keyword = searchInput.value.trim();
					searchBase.value = keyword ? `${SITE_META.searchQuery} ${keyword}` : SITE_META.searchQuery;
				});
			}
		})();
	</script>

	<script is:inline>
		(() => {
			const inviteLinks = document.querySelectorAll('[data-disabled-invite]');
			inviteLinks.forEach((link) => {
				link.addEventListener('click', (event) => {
					event.preventDefault();
					window.alert('暂未开放');
				});
			});
		})();
	</script>

	<script is:inline>
		(() => {
			const heading = document.querySelector('.typing-heading');
			const textNode = heading?.querySelector('.typing-text');
			const text = heading?.getAttribute('data-typing-text') || '';
			if (!heading || !textNode) return;

			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (prefersReducedMotion) {
				textNode.textContent = text;
				heading.classList.add('is-complete');
				return;
			}

			textNode.textContent = '';
			let index = 0;
			const startTyping = () => {
				const timer = window.setInterval(() => {
					index += 1;
					textNode.textContent = text.slice(0, index);
					if (index >= text.length) {
						window.clearInterval(timer);
						heading.classList.add('is-complete');
					}
				}, 70);
			};

			window.setTimeout(startTyping, 240);
		})();
	</script>
</Layout>
