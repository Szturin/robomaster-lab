---
import Layout from '../layouts/Layout.astro';

const highlights = [
	{ title: '机器人开发', text: '围绕 RoboMaster 开展机械、电控、视觉与整机协同开发。' },
	{ title: '赛事积累', text: '沉淀比赛经验、项目复盘、调试记录与工程资料。' },
	{ title: '开放协作', text: '欢迎对机器人、嵌入式、算法与赛事工程感兴趣的同学加入。' },
];

const sections = [
	{ name: '机械组', desc: '机构设计、加工装配、结构优化与实车调试。' },
	{ name: '电控组', desc: 'STM32、驱动控制、CAN 通信、任务调度与算法实现。' },
	{ name: '视觉组', desc: '目标识别、定位解算、串口联调与上位机协作。' },
	{ name: '运营组', desc: '战队宣传、活动组织、内容运营与对外展示。' },
];

const feishuInviteUrl = 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM';
const feishuDocUrl = 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig';
const robomasterUrl = 'https://www.robomaster.com/zh-CN';
---

<Layout title="科来战队 Robomaster Lab">
	<div class="page">
		<header class="hero">
			<nav class="nav">
				<div class="brand">科来战队 Robomaster Lab</div>
				<div class="nav-right">
					<div class="links">
						<a href={robomasterUrl} target="_blank" rel="noreferrer">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M5 4h6.6c3.62 0 5.9 1.86 5.9 4.82 0 2.04-1.04 3.47-2.9 4.12L19 20h-3.95l-3.87-6.43H8.4V20H5V4Zm3.4 2.72v4.2h3c1.67 0 2.58-.71 2.58-2.08 0-1.4-.9-2.12-2.58-2.12h-3Z" />
							</svg>
							<span>赛事官网</span>
						</a>
						<a href="/robomaster-lab/about">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M12 2.5 4 6v5.2c0 5.1 3.45 9.86 8 11.3 4.55-1.44 8-6.2 8-11.3V6l-8-3.5Zm0 2.18L18 7.3v3.9c0 4.05-2.57 7.96-6 9.28-3.43-1.32-6-5.23-6-9.28V7.3l6-2.62Z" />
							</svg>
							<span>关于我们</span>
						</a>
						<a href="/robomaster-lab/docs">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M6 3.5A2.5 2.5 0 0 0 3.5 6v12A2.5 2.5 0 0 0 6 20.5h12a2.5 2.5 0 0 0 2.5-2.5V8.41a2.5 2.5 0 0 0-.73-1.77l-2.41-2.41A2.5 2.5 0 0 0 15.59 3.5H6Zm0 1.5h9v3a1 1 0 0 0 1 1h3v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" />
							</svg>
							<span>技术文档</span>
						</a>
						<a href={feishuInviteUrl} target="_blank" rel="noreferrer">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M19.45 4.44c-1.32-.83-3.75-.76-5.73.26L8.4 7.45 5.2 7.1a1.6 1.6 0 0 0-1.75 1.97l.7 2.75-1.53 4.6a1.65 1.65 0 0 0 2.09 2.08l4.56-1.55 2.76.7a1.6 1.6 0 0 0 1.96-1.74l-.35-3.23 2.75-5.3c1.02-1.98 1.09-4.4.26-5.74-.26-.42-.63-.78-1.2-1.14Z" />
							</svg>
							<span>加入我们</span>
						</a>
					</div>
					<button type="button" class="theme-button nav-theme" data-theme-choice="system" aria-label="切换主题" title="切换主题">
						<svg viewBox="0 0 24 24" aria-hidden="true" data-theme-icon data-theme-state="system">
							<path class="sun-core" fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z" />
							<path class="sun-rays" fill="currentColor" d="M11 1h2v3h-2V1Zm0 19h2v3h-2v-3ZM1 11h3v2H1v-2Zm19 0h3v2h-3v-2ZM4.22 5.64l1.42-1.42 2.12 2.12-1.41 1.42-2.13-2.12Zm12.03 12.02 1.42-1.41 2.12 2.12-1.41 1.41-2.13-2.12ZM16.25 6.34l2.12-2.12 1.41 1.42-2.12 2.12-1.41-1.42ZM4.22 18.36l2.12-2.12 1.42 1.41-2.12 2.13-1.42-1.42Z" />
							<path class="moon-shape" fill="currentColor" d="M15.77 4.58A7.5 7.5 0 1 0 19.42 16a8 8 0 1 1-3.65-11.42Z" />
						</svg>
					</button>
				</div>
			</nav>

			<section class="hero-main">
				<div class="hero-copy">
					<p class="eyebrow">KELAI TEAM · ROBOMASTER LAB</p>
					<h1>科来战队 Robomaster Lab</h1>
					<p class="lead">
						展示战队风采、沉淀技术资料、组织招新协作，服务于 RoboMaster 项目展示与团队建设。
					</p>
					<div class="actions">
						<a class="primary" href={feishuDocUrl} target="_blank" rel="noreferrer">飞书文档</a>
						<a class="secondary" href="/robomaster-lab/docs">技术文档</a>
					</div>
				</div>
				<div class="hero-card">
					<div class="metric"><span>4</span><label>核心方向</label></div>
					<div class="metric"><span>24h</span><label>开放协作节奏</label></div>
					<div class="metric"><span>GitHub Pages</span><label>免费托管</label></div>
				</div>
			</section>
		</header>

		<main>
			<section id="about" class="panel">
				<div class="section-head">
					<div>
						<h2>关于我们</h2>
						<p class="section-note">主页保留简介，完整介绍请进入详细页面。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/about">查看详情</a>
				</div>
				<div class="grid three">
					{highlights.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section id="teams" class="panel">
				<div class="section-head">
					<div>
						<h2>小组方向</h2>
						<p class="section-note">主页展示概览，详细职责与学习路径见子页面。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/teams">查看详情</a>
				</div>
				<div class="grid four">
					{sections.map((item) => (
						<article class="card compact">
							<h3>{item.name}</h3>
							<p>{item.desc}</p>
						</article>
					))}
				</div>
			</section>

			<section class="panel callout">
				<div>
					<h2>欢迎加入科来战队 Robomaster Lab</h2>
					<p>你可以继续补充队伍成员页、比赛成绩页、招新页、项目展示页和开发手册页。</p>
				</div>
				<a class="primary" href={feishuInviteUrl} target="_blank" rel="noreferrer">通过飞书加入</a>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px;
	}

	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 14px 18px;
		margin-bottom: 20px;
		border-radius: 18px;
		background: color-mix(in srgb, var(--bg-start) 72%, transparent);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border: 1px solid var(--border);
		box-shadow: 0 10px 30px var(--shadow);
	}

	.brand {
		font-size: 20px;
		font-weight: 700;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.links {
		display: flex;
		gap: 0;
		color: var(--text-strong);
		background: var(--card-soft);
		border: 1px solid var(--border);
		border-radius: 14px;
		overflow: hidden;
	}

	.theme-button {
		border: 0;
		background: transparent;
		cursor: pointer;
	}

	.nav-theme {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 14px;
		background: var(--card-soft);
		border: 1px solid var(--border);
		color: var(--accent);
		flex: none;
	}

	.nav-theme svg {
		width: 18px;
		height: 18px;
	}

	.nav-theme .moon-shape {
		display: none;
	}

	html[data-theme='dark'] .nav-theme .sun-core,
	html[data-theme='dark'] .nav-theme .sun-rays {
		display: none;
	}

	html[data-theme='dark'] .nav-theme .moon-shape {
		display: block;
	}

	.links a,
	.actions a {
		text-decoration: none;
	}

	.links a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		border-right: 1px solid var(--border);
		color: var(--text-strong);
		font-weight: 600;
		letter-spacing: 0.01em;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.links a:last-child {
		border-right: 0;
	}

	.links a:hover {
		background: var(--accent-soft);
		color: var(--text-strong);
	}

	.links a svg {
		width: 16px;
		height: 16px;
		color: var(--accent);
		flex: none;
	}

	.hero-main {
		display: grid;
		grid-template-columns: 1.4fr 0.8fr;
		gap: 24px;
		align-items: center;
		padding: 12px 0 28px;
	}

	.eyebrow {
		color: var(--text-strong);
		letter-spacing: 0.22em;
		font-size: 12px;
	}

	h1 {
		font-size: clamp(38px, 6vw, 64px);
		line-height: 1.1;
		margin: 12px 0 20px;
		color: var(--text-strong);
		text-shadow: 0 0 24px color-mix(in srgb, var(--text-strong) 6%, transparent);
	}

	.lead,
	p {
		color: var(--text-muted);
		line-height: 1.7;
	}

	.actions {
		display: flex;
		gap: 16px;
		margin-top: 28px;
	}

	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 12px;
		font-weight: 700;
	}

	.primary {
		background: linear-gradient(135deg, var(--accent-strong), var(--accent));
		color: #0b0f14;
		box-shadow: 0 12px 30px color-mix(in srgb, var(--accent-strong) 22%, transparent);
	}

	.secondary {
		border: 1px solid var(--border);
		background: var(--card-soft);
		color: var(--text-strong);
	}

	.hero-card,
	.card,
	.panel {
		background: var(--card);
		border: 1px solid var(--border);
		backdrop-filter: blur(14px);
	}

	.hero-card {
		border-radius: 20px;
		padding: 24px;
		display: grid;
		gap: 16px;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--text-strong) 4%, transparent);
	}

	.metric {
		padding: 16px;
		border-radius: 16px;
		background: linear-gradient(180deg, var(--card-soft), color-mix(in srgb, var(--accent-soft) 70%, transparent));
		border: 1px solid var(--border);
	}

	.metric span {
		display: block;
		font-size: 28px;
		font-weight: 700;
		margin-bottom: 6px;
		color: var(--text-strong);
	}

	.metric label {
		color: var(--text-soft);
	}

	main {
		display: grid;
		gap: 24px;
		padding: 12px 0 48px;
	}

	.panel {
		border-radius: 24px;
		padding: 28px;
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 16px;
		margin-bottom: 4px;
	}

	.section-note {
		margin: 8px 0 0;
		color: var(--text-soft);
	}

	.text-link {
		color: var(--accent);
		font-weight: 700;
		white-space: nowrap;
	}

	.text-link:hover {
		color: color-mix(in srgb, var(--accent) 80%, white);
	}

	.grid {
		display: grid;
		gap: 16px;
		margin-top: 18px;
	}

	.three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.four {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.card {
		border-radius: 18px;
		padding: 20px;
	}

	.compact h3,
	.card h3 {
		margin-top: 0;
	}

	.callout {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}

	@media (max-width: 900px) {
		.hero-main,
		.three,
		.four,
		.callout {
			grid-template-columns: 1fr;
			display: grid;
		}

		.nav {
			position: sticky;
			top: 0;
			z-index: 50;
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
			padding: 12px 14px;
		}

		.links {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0;
			width: 100%;
		}

		.links a {
			padding: 9px 12px;
			border-right: 1px solid var(--border);
			border-bottom: 1px solid var(--border);
		}
	}

	@media (max-width: 640px) {
		.page {
			padding: 16px;
		}

		.actions {
			flex-direction: column;
		}

		.section-head {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>