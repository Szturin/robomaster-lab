---
import Layout from '../layouts/Layout.astro';
import '../styles/index.css';

const highlights = [
	{ title: '机器人开发', text: '围绕 RoboMaster 开展机械、电控、视觉与整机协同开发。' },
	{ title: '赛事积累', text: '沉淀比赛经验、项目复盘、调试记录与工程资料。' },
	{ title: '开放协作', text: '欢迎对机器人、嵌入式、算法与赛事工程感兴趣的同学加入。' },
];

const sections = [
	{ name: '机械组', desc: '结构设计、机构实现与整机装配调试。' },
	{ name: '电控组', desc: '嵌入式开发、控制系统与通信实现。' },
	{ name: '视觉组', desc: 'Linux 开发、MiniPC 部署与深度学习模型训练。' },
	{ name: '硬件组', desc: 'PCB设计、接口电源与电气可靠性验证。' },
	{ name: '运营组', desc: '宣传招新、项目统筹与物资协调保障。' },
];

const feishuInviteUrl = 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM';
const feishuDocUrl = 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig';
const robomasterUrl = 'https://www.robomaster.com/zh-CN';
const searchAction = 'https://www.google.com/search';
const searchQuery = 'site:szturin.github.io/robomaster-lab';
---

<Layout
	title="集美大学科来战队 RoboMaster Lab | 战队展示与技术文档"
	description="集美大学科来战队 RoboMaster Lab 官方展示页，包含战队介绍、成员培养、RoboMaster 技术文档、项目展示与招新协作入口。"
	canonicalPath="/robomaster-lab/"
>
	<div class="page">
		<header class="hero">
			<nav class="nav reveal-sequence reveal-delay-0">
				<div class="brand">TEF Robomaster Lab</div>
				<div class="nav-right">
					<form class="nav-search" action={searchAction} method="get" target="_blank" rel="noreferrer">
						<input type="hidden" name="q" value={searchQuery} data-search-base />
						<label class="search-field">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M10.5 4a6.5 6.5 0 1 1 0 13 6.5 6.5 0 0 1 0-13Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Zm8.91 11.5 1.59 1.59-1.41 1.41L18 18.91l1.41-1.41Z" />
							</svg>
							<input type="search" name="keyword" placeholder="搜索站内内容" aria-label="搜索站内内容" data-search-input />
						</label>
					</form>
					<div class="links">
						<a href={robomasterUrl} target="_blank" rel="noreferrer">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M5 4h6.6c3.62 0 5.9 1.86 5.9 4.82 0 2.04-1.04 3.47-2.9 4.12L19 20h-3.95l-3.87-6.43H8.4V20H5V4Zm3.4 2.72v4.2h3c1.67 0 2.58-.71 2.58-2.08 0-1.4-.9-2.12-2.58-2.12h-3Z" />
							</svg>
							<span>赛事官网</span>
						</a>
						<a href="/robomaster-lab/about">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M12 2.5 4 6v5.2c0 5.1 3.45 9.86 8 11.3 4.55-1.44 8-6.2 8-11.3V6l-8-3.5Zm0 2.18L18 7.3v3.9c0 4.05-2.57 7.96-6 9.28-3.43-1.32-6-5.23-6-9.28V7.3l6-2.62Z" />
							</svg>
							<span>关于我们</span>
						</a>
						<a href="/robomaster-lab/docs">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M6 3.5A2.5 2.5 0 0 0 3.5 6v12A2.5 2.5 0 0 0 6 20.5h12a2.5 2.5 0 0 0 2.5-2.5V8.41a2.5 2.5 0 0 0-.73-1.77l-2.41-2.41A2.5 2.5 0 0 0 15.59 3.5H6Zm0 1.5h9v3a1 1 0 0 0 1 1h3v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z" />
							</svg>
							<span>技术文档</span>
						</a>
						<a href={feishuInviteUrl} target="_blank" rel="noreferrer">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path fill="currentColor" d="M19.45 4.44c-1.32-.83-3.75-.76-5.73.26L8.4 7.45 5.2 7.1a1.6 1.6 0 0 0-1.75 1.97l.7 2.75-1.53 4.6a1.65 1.65 0 0 0 2.09 2.08l4.56-1.55 2.76.7a1.6 1.6 0 0 0 1.96-1.74l-.35-3.23 2.75-5.3c1.02-1.98 1.09-4.4.26-5.74-.26-.42-.63-.78-1.2-1.14Z" />
							</svg>
							<span>加入我们</span>
						</a>
					</div>
					<button type="button" class="theme-button nav-theme" data-theme-choice="system" aria-label="切换主题" title="切换主题">
						<svg viewBox="0 0 24 24" aria-hidden="true" data-theme-icon data-theme-state="system">
							<path class="sun-core" fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z" />
							<path class="sun-rays" fill="currentColor" d="M11 1h2v3h-2V1Zm0 19h2v3h-2v-3ZM1 11h3v2H1v-2Zm19 0h3v2h-3v-2ZM4.22 5.64l1.42-1.42 2.12 2.12-1.41 1.42-2.13-2.12Zm12.03 12.02 1.42-1.41 2.12 2.12-1.41 1.41-2.13-2.12ZM16.25 6.34l2.12-2.12 1.41 1.42-2.12 2.12-1.41-1.42ZM4.22 18.36l2.12-2.12 1.42 1.41-2.12 2.13-1.42-1.42Z" />
							<path class="moon-shape" fill="currentColor" d="M15.77 4.58A7.5 7.5 0 1 0 19.42 16a8 8 0 1 1-3.65-11.42Z" />
						</svg>
					</button>
				</div>
			</nav>

			<section class="hero-main">
				<div class="hero-ambient" aria-hidden="true">
					<span class="hero-orb orb-one"></span>
					<span class="hero-orb orb-two"></span>
					<span class="hero-scan"></span>
				</div>
				<div class="hero-copy">
					<p class="eyebrow reveal-sequence reveal-delay-1">TEF · ROBOMASTER LAB</p>
					<h1 class="typing-heading reveal-delay-2" data-typing-text="TEF Robomaster Lab" aria-label="TEF Robomaster Lab">
						<span class="typing-text" aria-hidden="true"></span>
					</h1>
					<p class="lead reveal-sequence reveal-delay-3">
						这里是集美大学科来战队 TEF RoboMaster Lab 的对外展示站，面向 RoboMaster 高校赛事与机器人工程实践，集中展示战队建设、技术文档、成员培养与招新协作信息。
					</p>
					<div class="actions reveal-sequence reveal-delay-4">
						<a class="primary" href={feishuDocUrl} target="_blank" rel="noreferrer">飞书文档</a>
						<a class="secondary" href="/robomaster-lab/docs">技术文档</a>
					</div>
				</div>
				<div class="hero-card reveal-sequence reveal-delay-5">
					<div class="metric"><span>前沿技术</span><label>聚焦具身智能、机器人设计与控制工程</label></div>
					<div class="metric"><span>自主创新</span><label>软件、硬件、机械系统自主研发</label></div>
					<div class="metric"><span>赛事驱动</span><label>以赛促研，持续迭代</label></div>
				</div>
			</section>
		</header>

		<main>
			<section id="about" class="panel reveal-on-scroll">
				<div class="section-head">
					<div>
						<h2>关于我们</h2>
						<p class="section-note">主页保留简介，完整介绍请进入集美大学科来战队详情页。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/about">查看科来战队介绍</a>
				</div>
				<div class="grid three">
					{highlights.map((item) => (
						<article class="card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</section>

			<section id="teams" class="panel reveal-on-scroll">
				<div class="section-head">
					<div>
						<h2>成员培养</h2>
						<p class="section-note">主页展示 RoboMaster 分工概览，详细职责与培养路径见子页面。</p>
					</div>
					<a class="text-link" href="/robomaster-lab/teams">查看成员培养详情</a>
				</div>
				<div class="team-switcher" aria-label="成员培养内容切换">
					<input class="team-toggle" type="radio" name="team-page" id="team-page-1" checked />
					<input class="team-toggle" type="radio" name="team-page" id="team-page-2" />

					<div class="team-pages">
						<div class="team-page page-one">
							{sections.slice(0, 3).map((item) => (
								<article class="card compact team-card">
									<h3>{item.name}</h3>
									<p>{item.desc}</p>
								</article>
							))}
						</div>
						<div class="team-page page-two">
							{sections.slice(3).map((item) => (
								<article class="card compact team-card">
									<h3>{item.name}</h3>
									<p>{item.desc}</p>
								</article>
							))}
						</div>
					</div>

					<div class="team-dots">
						<label for="team-page-1" aria-label="查看第一页"></label>
						<label for="team-page-2" aria-label="查看第二页"></label>
					</div>
				</div>
			</section>

			<section class="panel callout reveal-on-scroll">
				<div>
					<h2>欢迎加入 TEF Robomaster Lab</h2>
					<p>后续将逐步完善队伍成员、比赛成绩、招新信息、项目展示与开发手册等内容。</p>
				</div>
				<a class="primary" href={feishuInviteUrl} target="_blank" rel="noreferrer">通过飞书加入</a>
			</section>
		</main>
	</div>

	<script is:inline>
		(() => {
			const searchForm = document.querySelector('.nav-search');
			const searchInput = searchForm?.querySelector('[data-search-input]');
			const searchBase = searchForm?.querySelector('[data-search-base]');
			if (searchForm && searchInput instanceof HTMLInputElement && searchBase instanceof HTMLInputElement) {
				searchForm.addEventListener('submit', () => {
					const keyword = searchInput.value.trim();
					searchBase.value = keyword ? `${searchQuery} ${keyword}` : searchQuery;
				});
			}
		})();
	</script>

	<script is:inline>
		(() => {
			const heading = document.querySelector('.typing-heading');
			const textNode = heading?.querySelector('.typing-text');
			const text = heading?.getAttribute('data-typing-text') || '';
			if (!heading || !textNode) return;

			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (prefersReducedMotion) {
				textNode.textContent = text;
				heading.classList.add('is-complete');
				return;
			}

			textNode.textContent = '';
			let index = 0;
			const startTyping = () => {
				const timer = window.setInterval(() => {
					index += 1;
					textNode.textContent = text.slice(0, index);
					if (index >= text.length) {
						window.clearInterval(timer);
						heading.classList.add('is-complete');
					}
				}, 70);
			};

			window.setTimeout(startTyping, 240);
		})();
	</script>
</Layout>

<style>
	@keyframes hero-orb-float {
		0% {
			transform: translate3d(0, 0, 0) scale(1);
			opacity: 0.34;
		}
		50% {
			transform: translate3d(10px, -12px, 0) scale(1.05);
			opacity: 0.52;
		}
		100% {
			transform: translate3d(0, 0, 0) scale(1);
			opacity: 0.34;
		}
	}

	@keyframes hero-scan-sweep {
		0% {
			transform: translate3d(-8%, -10%, 0) rotate(12deg);
			opacity: 0;
		}
		20% {
			opacity: 0.2;
		}
		60% {
			opacity: 0.12;
		}
		100% {
			transform: translate3d(18%, 18%, 0) rotate(12deg);
			opacity: 0;
		}
	}

	@keyframes reveal-sequence {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes typing-caret-blink {
		0%,
		49% {
			border-color: color-mix(in srgb, var(--accent) 92%, transparent);
		}
		50%,
		100% {
			border-color: transparent;
		}
	}

	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 24px;
	}

	.hero {
		position: relative;
	}

	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 14px 18px;
		margin-bottom: 20px;
		border-radius: 18px;
		background: color-mix(in srgb, var(--bg-start) 72%, transparent);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border: 1px solid var(--border);
		box-shadow: 0 10px 30px var(--shadow);
	}

	.brand {
		font-size: 20px;
		font-weight: 700;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.nav-search {
		flex: none;
	}

	.search-field {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		width: 240px;
		height: 44px;
		padding: 0 14px;
		border-radius: 14px;
		background: var(--card-soft);
		border: 1px solid var(--border);
		color: var(--text-muted);
		transition:
			border-color var(--motion-duration-fast) ease,
			box-shadow var(--motion-duration-fast) ease,
			background var(--motion-duration-fast) ease;
	}

	.search-field:focus-within {
		border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
		box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent-soft) 72%, transparent);
	}

	.search-field svg {
		width: 16px;
		height: 16px;
		color: var(--accent);
		flex: none;
	}

	.search-field input {
		width: 100%;
		border: 0;
		outline: 0;
		background: transparent;
		color: var(--text-strong);
		font: inherit;
	}

	.search-field input::placeholder {
		color: var(--text-soft);
	}

	.links {
		display: flex;
		gap: 0;
		color: var(--text-strong);
		background: var(--card-soft);
		border: 1px solid var(--border);
		border-radius: 14px;
		overflow: hidden;
	}

	.theme-button {
		border: 0;
		background: transparent;
		cursor: pointer;
		transition:
			transform var(--motion-duration-fast) ease,
			box-shadow var(--motion-duration-fast) ease,
			background var(--motion-duration-fast) ease;
	}

	.theme-button:hover,
	.theme-button:focus-visible {
		transform: translateY(-1px);
	}

	.nav-theme {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 14px;
		background: var(--card-soft);
		border: 1px solid var(--border);
		color: var(--accent);
		flex: none;
	}

	.nav-theme:hover,
	.nav-theme:focus-visible {
		box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent-soft) 70%, transparent);
	}

	.nav-theme svg {
		width: 18px;
		height: 18px;
		transition: transform var(--motion-duration-base) var(--motion-ease);
	}

	html[data-theme='light'] .nav-theme svg {
		transform: rotate(-10deg);
	}

	html[data-theme='dark'] .nav-theme svg {
		transform: rotate(10deg);
	}

	.nav-theme .moon-shape {
		display: none;
	}

	html[data-theme='dark'] .nav-theme .sun-core,
	html[data-theme='dark'] .nav-theme .sun-rays {
		display: none;
	}

	html[data-theme='dark'] .nav-theme .moon-shape {
		display: block;
	}

	.links a,
	.actions a {
		text-decoration: none;
	}

	.links a {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		border-right: 1px solid var(--border);
		color: var(--text-strong);
		font-weight: 600;
		letter-spacing: 0.01em;
		transition:
			background var(--motion-duration-fast) ease,
			color var(--motion-duration-fast) ease,
			transform var(--motion-duration-fast) ease;
	}

	.links a::after {
		content: '';
		position: absolute;
		left: 14px;
		right: 14px;
		bottom: 6px;
		height: 1.5px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform var(--motion-duration-base) var(--motion-ease);
	}

	.links a:last-child {
		border-right: 0;
	}

	.links a:hover,
	.links a:focus-visible {
		background: var(--accent-soft);
		color: var(--text-strong);
		transform: translateY(-1px);
	}

	.links a:hover::after,
	.links a:focus-visible::after {
		transform: scaleX(1);
	}

	.links a svg {
		width: 16px;
		height: 16px;
		color: var(--accent);
		flex: none;
		transition: transform var(--motion-duration-fast) ease;
	}

	.links a:hover svg,
	.links a:focus-visible svg {
		transform: translate(1px, -1px);
	}

	.hero-main {
		position: relative;
		display: grid;
		grid-template-columns: 1.4fr 0.8fr;
		gap: 24px;
		align-items: center;
		padding: 12px 0 28px;
		isolation: isolate;
	}

	.hero-ambient {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
		border-radius: 28px;
		z-index: -1;
	}

	.hero-ambient::before {
		content: '';
		position: absolute;
		inset: 8% 4% auto 4%;
		height: 58%;
		background-image:
			linear-gradient(to bottom, color-mix(in srgb, var(--border) 42%, transparent) 1px, transparent 1px),
			linear-gradient(to right, color-mix(in srgb, var(--border) 26%, transparent) 1px, transparent 1px);
		background-size: 100% 20px, 20px 100%;
		opacity: 0.08;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.65), transparent 92%);
	}

	.hero-orb,
	.hero-scan {
		position: absolute;
		display: block;
	}

	.hero-orb {
		border-radius: 999px;
		filter: blur(18px);
		animation: hero-orb-float 12s ease-in-out infinite;
	}

	.orb-one {
		top: 4%;
		left: 10%;
		width: 240px;
		height: 240px;
		background: radial-gradient(circle, color-mix(in srgb, var(--accent) 26%, transparent), transparent 70%);
	}

	.orb-two {
		right: 12%;
		bottom: 10%;
		width: 190px;
		height: 190px;
		background: radial-gradient(circle, color-mix(in srgb, var(--bg-glow) 95%, transparent), transparent 72%);
		animation-delay: -5s;
	}

	.hero-scan {
		top: -12%;
		left: 12%;
		width: 42%;
		height: 170%;
		background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent) 12%, transparent), transparent);
		filter: blur(1px);
		opacity: 0;
		transform: rotate(12deg);
		animation: hero-scan-sweep 8.5s ease-in-out infinite;
	}

	.hero-copy > * {
		opacity: 0;
	}

	.reveal-sequence {
		animation: reveal-sequence 0.85s var(--motion-ease) both;
	}

	.reveal-delay-0 { animation-delay: 0.04s; }
	.reveal-delay-1 { animation-delay: 0.12s; }
	.reveal-delay-2 { animation-delay: 0.2s; }
	.reveal-delay-3 { animation-delay: 0.3s; }
	.reveal-delay-4 { animation-delay: 0.4s; }
	.reveal-delay-5 { animation-delay: 0.5s; }

	.eyebrow {
		color: var(--text-strong);
		letter-spacing: 0.22em;
		font-size: 12px;
		text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 10%, transparent);
	}

	h1 {
		font-size: clamp(38px, 6vw, 64px);
		line-height: 1.1;
		margin: 12px 0 20px;
		color: var(--text-strong);
		text-shadow: 0 0 24px color-mix(in srgb, var(--text-strong) 6%, transparent);
	}

	.typing-heading {
		opacity: 0;
		animation: reveal-sequence 0.85s var(--motion-ease) 0.2s both;
	}

	.typing-text {
		display: inline-block;
		min-height: 1.1em;
		white-space: nowrap;
		padding-right: 0.12em;
		border-right: 2px solid color-mix(in srgb, var(--accent) 92%, transparent);
		animation: typing-caret-blink 1s step-end infinite;
	}

	.typing-heading.is-complete .typing-text {
		border-right-color: transparent;
	}

	.lead,
	p {
