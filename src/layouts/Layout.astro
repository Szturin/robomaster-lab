---
interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
	noindex?: boolean;
}

const {
	title = 'RoboMaster Lab',
	description = '集美大学科来战队 RoboMaster Lab 展示战队风采、技术文档、成员培养与招新协作信息。',
	canonicalPath,
	ogImage,
	noindex = false,
} = Astro.props;

const site = Astro.site;
const baseUrl = site ? new URL(import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`, site) : undefined;
const canonicalUrl = site ? new URL(canonicalPath ?? Astro.url.pathname, site).toString() : undefined;
const defaultOgImage = baseUrl ? new URL('og-cover.svg', baseUrl).toString() : undefined;
const ogImageUrl = ogImage ? (site ? new URL(ogImage, site).toString() : ogImage) : defaultOgImage;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: '集美大学科来战队 RoboMaster Lab',
	url: canonicalUrl ?? site?.toString(),
	logo: defaultOgImage,
	description,
	sameAs: [
		'https://github.com/Szturin/robomaster-lab',
		'https://space.bilibili.com/651717103',
	],
};

const footerSections = [
	{
		title: '文档',
		links: [
			{ name: '首页', href: '/robomaster-lab/' },
			{ name: '关于我们', href: '/robomaster-lab/about' },
			{ name: '成员培养', href: '/robomaster-lab/teams' },
			{ name: '技术文档', href: '/robomaster-lab/docs' },
		],
	},
	{
		title: '社区',
		links: [
			{ name: 'GitHub 仓库', href: 'https://github.com/Szturin/robomaster-lab', external: true },
			{ name: '飞书文档', href: 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig', external: true },
			{ name: '加入飞书群', href: 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM', external: true },
		],
	},
	{
		title: '媒体',
		links: [{ name: 'B站主页', href: 'https://space.bilibili.com/651717103', external: true }],
	},
	{
		title: '相关链接',
		links: [{ name: '赛事官网', href: 'https://www.robomaster.com/zh-CN', external: true }],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`.replace('/robomaster-labfavicon', '/robomaster-lab/favicon')} />
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`.replace('/robomaster-labfavicon', '/robomaster-lab/favicon')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<meta property="og:locale" content="zh_CN" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
		<script is:inline>
			(() => {
				const key = 'theme-preference';
				const root = document.documentElement;
				const getSystemTheme = () =>
					window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				const saved = localStorage.getItem(key) || 'system';
				const resolved = saved === 'system' ? getSystemTheme() : saved;
				root.dataset.theme = resolved;
				root.dataset.themePreference = saved;
			})();
		</script>
	</head>
	<body>
		<div class="shell">
			<main class="content">
				<slot />
			</main>
			<footer class="site-footer">
				<div class="footer-inner reveal-on-scroll is-visible">
					<div class="footer-grid">
						{footerSections.map((section) => (
							<section class="footer-column">
								<h3>{section.title}</h3>
								<ul>
									{section.links.map((link) => (
										<li>
											<a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
												<span>{link.name}</span>
												{link.external && (
													<svg viewBox="0 0 24 24" aria-hidden="true">
														<path fill="currentColor" d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z" />
													</svg>
												)}
											</a>
										</li>
									))}
								</ul>
							</section>
						))}
					</div>
					<p class="footer-note">
						<a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
						© 2026 TEF
					</p>
				</div>
			</footer>
		</div>
		<script is:inline>
			(() => {
				const key = 'theme-preference';
				const root = document.documentElement;
				const media = window.matchMedia('(prefers-color-scheme: dark)');
				const getSystemTheme = () => (media.matches ? 'dark' : 'light');
				const apply = (choice) => {
					const resolved = choice === 'system' ? getSystemTheme() : choice;
					root.dataset.theme = resolved;
					root.dataset.themePreference = choice;
					localStorage.setItem(key, choice);
					const icon = document.querySelector('[data-theme-icon]');
					if (icon) {
						icon.setAttribute('data-theme-state', resolved);
					}
				};
				document.querySelectorAll('.theme-button').forEach((button) => {
					button.addEventListener('click', () => {
						const current = root.dataset.theme || getSystemTheme();
						apply(current === 'dark' ? 'light' : 'dark');
					});
				});
				media.addEventListener('change', () => {
					if ((root.dataset.themePreference || 'system') === 'system') {
						apply('system');
					}
				});

				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const revealElements = document.querySelectorAll('.reveal-on-scroll');
				if (!prefersReducedMotion && 'IntersectionObserver' in window && revealElements.length > 0) {
					const observer = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('is-visible');
									observer.unobserve(entry.target);
								}
							});
						},
						{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
					);
					revealElements.forEach((element) => observer.observe(element));
				} else {
					revealElements.forEach((element) => element.classList.add('is-visible'));
				}

				apply(root.dataset.themePreference || localStorage.getItem(key) || 'system');
			})();
		</script>
	</body>
</html>

<style>
	:root {
		font-family: Inter, 'PingFang SC', 'Microsoft YaHei', sans-serif;
		color-scheme: dark;
		--bg-start: #0b0f14;
		--bg-end: #121821;
		--bg-accent: rgba(249, 115, 22, 0.14);
		--bg-glow: rgba(255, 255, 255, 0.04);
		--text: #f4f7fb;
		--text-strong: #f8fafc;
		--text-muted: #c7d0db;
		--text-soft: #98a2b3;
		--card: rgba(18, 24, 33, 0.82);
		--card-soft: rgba(255, 255, 255, 0.03);
		--border: rgba(255, 255, 255, 0.08);
		--border-strong: rgba(140, 168, 197, 0.16);
		--accent: #fb923c;
		--accent-strong: #f97316;
		--accent-soft: rgba(249, 115, 22, 0.08);
		--shadow: rgba(0, 0, 0, 0.18);
		--motion-duration-fast: 180ms;
		--motion-duration-base: 360ms;
		--motion-duration-slow: 900ms;
		--motion-ease: cubic-bezier(0.22, 1, 0.36, 1);
	}

	html[data-theme='light'] {
		color-scheme: light;
		--bg-start: #f7f8fa;
		--bg-end: #eef2f6;
		--bg-accent: rgba(249, 115, 22, 0.08);
		--bg-glow: rgba(255, 255, 255, 0.65);
		--text: #18212b;
		--text-strong: #0f1720;
		--text-muted: #4b5563;
		--text-soft: #6b7280;
		--card: rgba(255, 255, 255, 0.88);
		--card-soft: rgba(255, 255, 255, 0.78);
		--border: rgba(15, 23, 32, 0.08);
		--border-strong: rgba(148, 163, 184, 0.22);
		--accent: #ea580c;
		--accent-strong: #f97316;
		--accent-soft: rgba(249, 115, 22, 0.1);
		--shadow: rgba(15, 23, 32, 0.08);
	}

	@keyframes background-drift {
		0% {
			transform: translate3d(-2%, 0, 0);
			opacity: 0.45;
		}
		50% {
			transform: translate3d(2%, -1.5%, 0);
			opacity: 0.7;
		}
		100% {
			transform: translate3d(-2%, 0, 0);
			opacity: 0.45;
		}
	}

	@keyframes grid-shift {
		0% {
			transform: translateY(0);
		}
		100% {
			transform: translateY(18px);
		}
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		color: var(--text);
		background:
			radial-gradient(circle at top, var(--bg-accent), transparent 26%),
			radial-gradient(circle at top right, var(--bg-glow), transparent 20%),
			linear-gradient(180deg, var(--bg-start) 0%, var(--bg-end) 100%);
	}

	body {
		display: flex;
		flex-direction: column;
		position: relative;
		isolation: isolate;
	}

	body::before,
	body::after {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: -1;
	}

	body::before {
		background:
			radial-gradient(circle at 18% 16%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 24%),
			radial-gradient(circle at 84% 12%, color-mix(in srgb, var(--bg-glow) 92%, transparent), transparent 20%);
		opacity: 0.55;
		animation: background-drift 18s ease-in-out infinite;
	}

	body::after {
		background-image:
			linear-gradient(to bottom, color-mix(in srgb, var(--border) 52%, transparent) 1px, transparent 1px),
			linear-gradient(to right, color-mix(in srgb, var(--border) 30%, transparent) 1px, transparent 1px);
		background-size: 100% 18px, 18px 100%;
		opacity: 0.045;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4), transparent 78%);
		animation: grid-shift 20s linear infinite;
	}

	a {
		color: inherit;
	}

	* {
		box-sizing: border-box;
	}

	.reveal-on-scroll {
		opacity: 0;
		transform: translateY(16px);
		transition:
			opacity var(--motion-duration-slow) var(--motion-ease),
			transform var(--motion-duration-slow) var(--motion-ease);
	}

	.reveal-on-scroll.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.content {
		flex: 1;
	}

	.site-footer {
		padding: 32px 16px 28px;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 22px;
		border-top: 1px solid var(--border-strong);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 28px;
	}

	.footer-column h3 {
		margin: 0 0 16px;
		font-size: 18px;
		color: var(--text-strong);
	}

	.footer-column ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 12px;
	}

	.footer-column a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: var(--text-muted);
		transition:
			color var(--motion-duration-fast) ease,
			transform var(--motion-duration-fast) ease;
	}

	.footer-column a:hover,
	.footer-column a:focus-visible {
		color: var(--accent);
		transform: translateX(2px);
	}

	.footer-column svg {
		width: 14px;
		height: 14px;
		flex: none;
		transition: transform var(--motion-duration-fast) ease;
	}

	.footer-column a:hover svg,
	.footer-column a:focus-visible svg {
		transform: translate(1px, -1px);
	}

	.footer-note {
		margin: 28px 0 0;
		text-align: center;
		color: var(--text-soft);
		font-size: 14px;
	}

	.footer-note a {
		text-decoration: none;
		color: var(--accent);
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}

		body::before,
		body::after {
			animation: none;
		}

		.reveal-on-scroll {
			opacity: 1;
			transform: none;
		}
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 22px;
		}
	}
</style>
