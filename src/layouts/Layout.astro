---
interface Props {
	title?: string;
}

const { title = 'RoboMaster Lab' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		font-family: Inter, 'PingFang SC', 'Microsoft YaHei', sans-serif;
		color: #e5eef7;
		background: #08111f;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at top, rgba(41, 98, 255, 0.18), transparent 32%),
			linear-gradient(180deg, #08111f 0%, #0d1728 100%);
		}

	a {
		color: inherit;
	}

	* {
		box-sizing: border-box;
	}
</style>