---
import '../styles/layout.css';
import { FOOTER_SECTIONS, SITE_LINKS, SITE_META } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	ogImage?: string;
	noindex?: boolean;
}

const {
	title = SITE_META.defaultTitle,
	description = SITE_META.defaultDescription,
	canonicalPath,
	ogImage,
	noindex = false,
} = Astro.props;

const site = Astro.site;
const baseUrl = site ? new URL(import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`, site) : undefined;
const canonicalUrl = site ? new URL(canonicalPath ?? Astro.url.pathname, site).toString() : undefined;
const defaultOgImage = baseUrl ? new URL('og-cover.svg', baseUrl).toString() : undefined;
const ogImageUrl = ogImage ? (site ? new URL(ogImage, site).toString() : ogImage) : defaultOgImage;
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_META.organizationName,
	url: canonicalUrl ?? site?.toString(),
	logo: defaultOgImage,
	description,
	sameAs: [SITE_LINKS.github, SITE_LINKS.bilibili],
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<meta property="og:locale" content="zh_CN" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
		<script is:inline>
			(() => {
				const key = 'theme-preference';
				const root = document.documentElement;
				const getSystemTheme = () =>
					window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				const saved = localStorage.getItem(key) || 'system';
				const resolved = saved === 'system' ? getSystemTheme() : saved;
				root.dataset.theme = resolved;
				root.dataset.themePreference = saved;
			})();
		</script>
	</head>
	<body>
		<div class="shell">
			<main class="content">
				<slot />
			</main>
			<footer class="site-footer">
				<div class="footer-inner reveal-on-scroll is-visible">
					<div class="footer-grid">
						{FOOTER_SECTIONS.map((section) => (
							<section class="footer-column">
								<h3>{section.title}</h3>
								<ul>
									{section.links.map((link) => (
										<li>
											<a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
												<span>{link.name}</span>
												{link.external && (
													<svg viewBox="0 0 24 24" aria-hidden="true">
														<path fill="currentColor" d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z" />
													</svg>
												)}
											</a>
										</li>
									))}
								</ul>
							</section>
						))}
					</div>
					<p class="footer-note">
						<a href={SITE_LINKS.astro} target="_blank" rel="noreferrer">Astro</a>
						© 2026 TEF
					</p>
				</div>
			</footer>
		</div>
		<script is:inline>
			(() => {
				const key = 'theme-preference';
				const root = document.documentElement;
				const media = window.matchMedia('(prefers-color-scheme: dark)');
				const getSystemTheme = () => (media.matches ? 'dark' : 'light');
				const apply = (choice) => {
					const resolved = choice === 'system' ? getSystemTheme() : choice;
					root.dataset.theme = resolved;
					root.dataset.themePreference = choice;
					localStorage.setItem(key, choice);
					const icon = document.querySelector('[data-theme-icon]');
					if (icon) {
						icon.setAttribute('data-theme-state', resolved);
					}
				};
				document.querySelectorAll('.theme-button').forEach((button) => {
					button.addEventListener('click', () => {
						const current = root.dataset.theme || getSystemTheme();
						apply(current === 'dark' ? 'light' : 'dark');
					});
				});
				media.addEventListener('change', () => {
					if ((root.dataset.themePreference || 'system') === 'system') {
						apply('system');
					}
				});

				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const revealElements = document.querySelectorAll('.reveal-on-scroll');
				if (!prefersReducedMotion && 'IntersectionObserver' in window && revealElements.length > 0) {
					const observer = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('is-visible');
									observer.unobserve(entry.target);
								}
							});
						},
						{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
					);
					revealElements.forEach((element) => observer.observe(element));
				} else {
					revealElements.forEach((element) => element.classList.add('is-visible'));
				}

				apply(root.dataset.themePreference || localStorage.getItem(key) || 'system');
			})();
		</script>
	</body>
</html>
