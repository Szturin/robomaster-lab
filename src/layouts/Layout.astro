---
interface Props {
	title?: string;
}

const { title = 'RoboMaster Lab' } = Astro.props;

const footerLinks = [
	{
		name: 'GitHub',
		href: 'https://github.com/Szturin/robomaster-lab',
		icon: 'github',
	},
	{
		name: 'Docs',
		href: '/robomaster-lab/docs',
		icon: 'docs',
	},
	{
		name: 'Feishu',
		href: 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM',
		icon: 'feishu',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<main class="content">
				<slot />
			</main>
			<footer class="site-footer">
				<div class="footer-inner">
					<p class="footer-note">
						<a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
						© 2026 TEF
					</p>
					<nav class="footer-links" aria-label="Footer links">
						{footerLinks.map((link) => (
							<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined} aria-label={link.name} title={link.name}>
								{link.icon === 'github' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path fill="currentColor" d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.36 22.1c.58.1.79-.25.79-.56v-2.18c-3.18.69-3.85-1.35-3.85-1.35-.52-1.31-1.26-1.66-1.26-1.66-1.03-.7.08-.69.08-.69 1.14.08 1.73 1.16 1.73 1.16 1.01 1.74 2.66 1.24 3.31.95.1-.74.4-1.24.72-1.53-2.54-.29-5.21-1.27-5.21-5.66 0-1.25.45-2.28 1.17-3.08-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.14 1.18a10.9 10.9 0 0 1 5.72 0c2.17-1.5 3.13-1.18 3.13-1.18.62 1.57.23 2.73.11 3.02.73.8 1.17 1.83 1.17 3.08 0 4.4-2.67 5.36-5.22 5.65.41.36.77 1.08.77 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
									</svg>
								)}
								{link.icon === 'docs' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path fill="currentColor" d="M6 3.5A2.5 2.5 0 0 0 3.5 6v12A2.5 2.5 0 0 0 6 20.5h12a2.5 2.5 0 0 0 2.5-2.5V8.41a2.5 2.5 0 0 0-.73-1.77l-2.41-2.41A2.5 2.5 0 0 0 15.59 3.5H6Zm0 1.5h9v3a1 1 0 0 0 1 1h3v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm2 7.25a.75.75 0 0 1 .75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1-.75-.75Zm0 3.5a.75.75 0 0 1 .75-.75h6.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1-.75-.75Z" />
									</svg>
								)}
								{link.icon === 'feishu' && (
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path fill="currentColor" d="M19.45 4.44c-1.32-.83-3.75-.76-5.73.26L8.4 7.45 5.2 7.1a1.6 1.6 0 0 0-1.75 1.97l.7 2.75-1.53 4.6a1.65 1.65 0 0 0 2.09 2.08l4.56-1.55 2.76.7a1.6 1.6 0 0 0 1.96-1.74l-.35-3.23 2.75-5.3c1.02-1.98 1.09-4.4.26-5.74-.26-.42-.63-.78-1.2-1.14Z" />
									</svg>
								)}
							</a>
						))}
					</nav>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		font-family: Inter, 'PingFang SC', 'Microsoft YaHei', sans-serif;
		color: #f4f7fb;
		background: #0b0f14;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at top, rgba(249, 115, 22, 0.14), transparent 26%),
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.04), transparent 20%),
			linear-gradient(180deg, #0b0f14 0%, #121821 100%);
	}

	body {
		display: flex;
		flex-direction: column;
	}

	a {
		color: inherit;
	}

	* {
		box-sizing: border-box;
	}

	.shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.content {
		flex: 1;
	}

	.site-footer {
		padding: 24px 16px 32px;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 14px;
		padding-top: 18px;
		border-top: 1px solid rgba(140, 168, 197, 0.16);
		text-align: center;
	}

	.footer-note {
		margin: 0;
		color: #98a2b3;
		font-size: 14px;
	}

	.footer-note a {
		text-decoration: none;
		color: #fb923c;
	}

	.footer-links {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.footer-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		text-decoration: none;
		transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
		color: #d6deea;
	}

	.footer-links a:hover {
		transform: translateY(-2px);
		border-color: rgba(249, 115, 22, 0.45);
		background: rgba(249, 115, 22, 0.08);
		color: #ffffff;
	}

	.footer-links svg {
		width: 18px;
		height: 18px;
	}

	@media (max-width: 640px) {
		.footer-inner {
			padding-top: 16px;
		}
	}
</style>