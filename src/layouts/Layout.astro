---
interface Props {
	title?: string;
}

const { title = 'RoboMaster Lab' } = Astro.props;

const footerSections = [
	{
		title: '文档',
		links: [
			{ name: '首页', href: '/robomaster-lab/' },
			{ name: '关于我们', href: '/robomaster-lab/about' },
			{ name: '小组方向', href: '/robomaster-lab/teams' },
			{ name: '技术文档', href: '/robomaster-lab/docs' },
		],
	},
	{
		title: '社区',
		links: [
			{ name: 'GitHub 仓库', href: 'https://github.com/Szturin/robomaster-lab', external: true },
			{ name: '飞书文档', href: 'https://ecnxe597phb3.feishu.cn/wiki/Ku6PwOIlLiC7FnklO5MccZUZnig', external: true },
			{ name: '加入飞书群', href: 'https://ecnxe597phb3.feishu.cn/invite/member/TYzmSefnMiM', external: true },
		],
	},
	{
		title: '媒体',
		links: [
			{ name: 'B站主页', href: 'https://space.bilibili.com/651717103', external: true },
		],
	},
	{
		title: '相关链接',
		links: [
			{ name: '赛事官网', href: 'https://www.robomaster.com/zh-CN', external: true },
		],
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<main class="content">
				<slot />
			</main>
			<footer class="site-footer">
				<div class="footer-inner">
					<div class="footer-grid">
						{footerSections.map((section) => (
							<section class="footer-column">
								<h3>{section.title}</h3>
								<ul>
									{section.links.map((link) => (
										<li>
											<a href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noreferrer' : undefined}>
												<span>{link.name}</span>
												{link.external && (
													<svg viewBox="0 0 24 24" aria-hidden="true">
														<path fill="currentColor" d="M14 3h7v7h-2V6.41l-9.29 9.3-1.42-1.42 9.3-9.29H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z" />
													</svg>
												)}
											</a>
										</li>
									))}
								</ul>
							</section>
						))}
					</div>
					<p class="footer-note">
						<a href="https://astro.build" target="_blank" rel="noreferrer">Astro</a>
						© 2026 TEF
					</p>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		font-family: Inter, 'PingFang SC', 'Microsoft YaHei', sans-serif;
		color: #f4f7fb;
		background: #0b0f14;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at top, rgba(249, 115, 22, 0.14), transparent 26%),
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.04), transparent 20%),
			linear-gradient(180deg, #0b0f14 0%, #121821 100%);
	}

	body {
		display: flex;
		flex-direction: column;
	}

	a {
		color: inherit;
	}

	* {
		box-sizing: border-box;
	}

	.shell {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.content {
		flex: 1;
	}

	.site-footer {
		padding: 32px 16px 28px;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 22px;
		border-top: 1px solid rgba(140, 168, 197, 0.16);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 28px;
	}

	.footer-column h3 {
		margin: 0 0 16px;
		font-size: 18px;
		color: #f8fafc;
	}

	.footer-column ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 12px;
	}

	.footer-column a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: #c7d0db;
		transition: color 0.2s ease;
	}

	.footer-column a:hover {
		color: #fb923c;
	}

	.footer-column svg {
		width: 14px;
		height: 14px;
		flex: none;
	}

	.footer-note {
		margin: 28px 0 0;
		text-align: center;
		color: #98a2b3;
		font-size: 14px;
	}

	.footer-note a {
		text-decoration: none;
		color: #fb923c;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 22px;
		}
	}
</style>
